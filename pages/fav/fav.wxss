/* ===== 全局 ===== */
page { background: #1a1a1a; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
.bg-wrapper { position: relative; height: 100vh; overflow: hidden; display: flex; flex-direction: column; }
.bg { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; }
.app { position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; background: transparent; }
.page-content { flex: 1; overflow-y: auto; padding: 24rpx 24rpx 180rpx 24rpx; }
.page-content::-webkit-scrollbar { width: 0; }

/* ===== 标题栏 ===== */
.header {
  padding: 20rpx 24rpx; display: flex; justify-content: flex-end; align-items: center; flex-shrink: 0;
  background: rgba(255,245,240,0.25);
  backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  border-bottom: 1px solid rgba(255,255,255,0.12); gap: 12px;
  padding-top: calc(48rpx + env(safe-area-inset-top));
}
.header-left { display: flex; align-items: center; gap: 12rpx; margin-right: auto; }
.logo-icon { width: 48rpx; height: 48rpx; }
.header-title { font-size: 30rpx; font-weight: 700; color: #4A3034; }
.header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 2rpx; }
.header-date { font-size: 22rpx; color: rgba(74,48,52,0.5); }
.header-days { font-size: 22rpx; color: rgba(74,48,52,0.5); }

/* ===== 毛玻璃卡片 ===== */
.card {
  background: rgba(255,245,240,0.25);
  backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  border-radius: 28rpx;
  border: 1px solid rgba(255,255,255,0.12);
  padding: 24rpx;
  margin-bottom: 12rpx;
}

/* ===== 按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #F5A0A8, #E88892);
  color: #fff; border: none; border-radius: 16rpx;
  padding: 20rpx 32rpx; font-size: 28rpx; font-weight: 600;
  text-align: center; width: 100%; line-height: 1;
}
.btn-primary:active { opacity: 0.8; }
.btn-primary::after { border: none; }

/* ===== 图片预览 ===== */
.img-preview { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 300; display: none; align-items: center; justify-content: center; }
.img-preview.show { display: flex; }
.preview-img { max-width: 90%; max-height: 80vh; border-radius: 16rpx; }
.btn-light {
  background: rgba(255,245,240,0.55);
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 16rpx; color: #4A3034; padding: 12rpx 24rpx; font-size: 22rpx;
  line-height: 1; display: inline-flex; align-items: center; gap: 8rpx;
}
.btn-light::after { border: none; }
.btn-light:active { background: rgba(255,245,240,0.8); }

/* ===== 搜索框 ===== */
.search-box { margin-bottom: 12rpx; }
.search-input {
  width: 100%; padding: 16rpx 24rpx; border-radius: 16rpx;
  background: rgba(255,245,240,0.4); border: 1px solid rgba(255,255,255,0.2);
  color: #4A3034; font-size: 26rpx;
}
.search-input::placeholder { color: rgba(74,48,52,0.35); }

/* ===== 分类标签 ===== */
.cats { display: flex; gap: 12rpx; margin-bottom: 20rpx; white-space: nowrap; }
.cat {
  display: inline-block; padding: 10rpx 28rpx; border-radius: 32rpx;
  font-size: 24rpx; background: rgba(255,245,240,0.4); color: rgba(74,48,52,0.5);
  flex-shrink: 0; line-height: 1.2;
}
.cat.active { background: #F5A0A8; color: #fff; font-weight: 600; }

/* ===== 推荐卡片 ===== */
.recommend-card {
  background: linear-gradient(135deg, rgba(245,160,168,0.15), rgba(255,245,240,0.2));
  border-color: rgba(245,160,168,0.2);
}
.recommend-label { font-size: 22rpx; color: #E88892; display: block; }
.recommend-name { font-size: 28rpx; font-weight: 600; color: #4A3034; display: block; margin: 8rpx 0; }
.recommend-reason { font-size: 22rpx; color: rgba(74,48,52,0.5); }

/* ===== 菜品卡片 ===== */
.dish-card { display: flex; gap: 12rpx; align-items: flex-start; padding: 24rpx 28rpx; margin-bottom: 20rpx; }
.dish-img { width: 160rpx; height: 160rpx; border-radius: 16rpx; flex-shrink: 0; background: rgba(255,255,255,0.08); }
.dish-emoji { width: 160rpx; height: 160rpx; border-radius: 16rpx; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 60rpx; background: rgba(255,255,255,0.08); }
.dish-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.dish-name-row { display: flex; align-items: center; gap: 10rpx; }
.dish-name { font-size: 32rpx; font-weight: 600; color: #4A3034; }
.dish-rating { font-size: 26rpx; color: #E88892; font-weight: 600; }
.dish-tags { display: flex; flex-wrap: wrap; gap: 6rpx; margin: 8rpx 0; }
.tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 16rpx; background: rgba(255,245,240,0.3); color: rgba(74,48,52,0.5); }
.dish-act { display: flex; align-items: center; justify-content: flex-start; gap: 8rpx; margin-top: 6rpx; }
.dish-act .btn-light { font-size: 24rpx !important; padding: 8rpx 18rpx !important; min-width: 0 !important; height: auto !important; line-height: 1.4 !important; margin: 0 !important; border-radius: 12rpx !important; }
.fav-btn { background: rgba(255,245,240,0.3) !important; font-size: 22rpx !important; padding: 6rpx 14rpx !important; min-width: 0 !important; height: auto !important; line-height: 1.4 !important; margin: 0 !important; border-radius: 12rpx !important; }

/* ===== 随机按钮 ===== */
.float-btn {
  position: fixed; right: 32rpx; bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 90rpx; height: 90rpx; border-radius: 50%;
  background: rgba(255,245,240,0.3);
  backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.12);
  display: flex; align-items: center; justify-content: center;
  z-index: 20; box-shadow: 0 4rpx 20rpx rgba(245,160,168,0.3);
}
.float-btn:active { opacity: 0.8; }

/* ===== 空状态 ===== */
.empty-hint { text-align: center; padding: 120rpx 0; color: rgba(74,48,52,0.35); font-size: 26rpx; }

/* ===== 弹窗 ===== */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 50; display: none; align-items: center; justify-content: center; }
.modal-overlay.show { display: flex; }
.modal-box { background: rgba(255,245,240,0.95); backdrop-filter: blur(20px); border-radius: 28rpx; padding: 40rpx; width: 520rpx; max-height: 80vh; overflow-y: auto; }
.modal-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; text-align: center; color: #4A3034; }
.modal-img { width: 200rpx; height: 200rpx; border-radius: 16rpx; display: block; margin: 0 auto 16rpx; background: rgba(255,255,255,0.1); }
.modal-emoji { font-size: 80rpx; text-align: center; display: block; margin: 0 auto 16rpx; }
.modal-name { font-size: 32rpx; font-weight: 600; text-align: center; color: #4A3034; }
.modal-rating { font-size: 24rpx; color: #E88892; text-align: center; margin: 8rpx 0 20rpx; }
.modal-btn { width: 100%; padding: 20rpx; border-radius: 16rpx; margin-bottom: 12rpx; text-align: center; font-size: 26rpx; background: rgba(245,160,168,0.1); color: #4A3034; line-height: 1; border: none; }
.modal-btn::after { border: none; }
.modal-btn:active { opacity: 0.7; }
.modal-btn.primary { color: #fff; background: linear-gradient(135deg, #F5A0A8, #E88892); }
.modal-btn.cancel { background: transparent; color: rgba(74,48,52,0.35); }

/* ===== 自定义Toast ===== */
.toast-overlay { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); z-index: 200; display: none; align-items: center; justify-content: center; pointer-events: none; }
.toast-overlay.show { display: flex; }
.toast-box {
  background: rgba(255,245,240,0.25);
  backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 28rpx; padding: 20rpx 40rpx;
  display: flex; align-items: center; gap: 12rpx;
  white-space: nowrap;
}
.toast-icon { width: 48rpx; height: 48rpx; border-radius: 8rpx; flex-shrink: 0; }
.toast-text { font-size: 28rpx; color: #4A3034; font-weight: 500; white-space: nowrap; }

/* ===== 飞入动效 ===== */
.fly-item { position: fixed; z-index: 200; pointer-events: none; width: 36px; height: 36px; border-radius: 6px; overflow: hidden; background: rgba(255,255,255,0.2); transform: translate(-50%,-50%); opacity: 0; }
.fly-item image { width: 100%; height: 100%; object-fit: cover; }
.fly-item text { display: flex; align-items: center; justify-content: center; font-size: 24px; width: 100%; height: 100%; }
.fly-active { opacity: 1; }
/* 动画通过JS控制 transition */
.fly-item { transition: all 0.5s cubic-bezier(0.25,0.46,0.45,0.94); }
