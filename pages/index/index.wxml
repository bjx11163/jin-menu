<view class="bg-wrapper">
  <image class="bg" src="/img/bg.jpg" mode="aspectFill"></image>
  <view class="app">
    <view class="header">
      <view class="header-left">
        <image class="logo-icon" src="/img/logo_icon.png" mode="aspectFit"></image>
        <text class="header-title">小金的专属</text>
      </view>
      <view class="header-right">
        <text class="header-date">{{dateStr}}</text>
        <text class="header-days">💝 {{anniversaryDays}}天</text>
      </view>
    </view>
    <scroll-view class="page-content" scroll-y>
      <view class="search-box">
        <input class="search-input" placeholder="🔍 搜搜今天想吃啥..." bindinput="onSearch" value="{{searchText}}"></input>
      </view>
      <scroll-view class="cats" scroll-x>
        <view wx:for="{{categories}}" wx:key="*this" class="cat {{currentCat === item ? 'active' : ''}}" bindtap="switchCat" data-cat="{{item}}">{{item}}</view>
      </scroll-view>
      <view class="card recommend-card" wx:if="{{recommendDish}}" bindtap="addRecommend">
        <text class="recommend-label">🤖 猜你想吃</text>
        <text class="recommend-name">{{recommendDish.name}} ⭐{{recommendDish.rating}}</text>
        <text class="recommend-reason">{{recommendReason}}</text>
      </view>
      <view wx:for="{{displayDishes}}" wx:key="id" class="card dish-card">
        <image class="dish-img" src="{{item.photo}}" mode="aspectFill" wx:if="{{item.photo}}" data-src="{{item.photo}}" bindtap="previewImg"></image>
        <text class="dish-emoji" wx:else>{{item.emoji}}</text>
        <view class="dish-info">
          <view class="dish-name-row">
            <text class="dish-name">{{item.name}}</text>
            <text wx:if="{{item.rating}}" class="dish-rating">⭐{{item.rating}}</text>
          </view>
          <view class="dish-tags">
            <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
          </view>
          <view class="dish-act">
            <button class="btn-light" bindtap="addToCart" data-id="{{item.id}}">+ 点菜</button>
            <button class="btn-light fav-btn" bindtap="doFav" data-id="{{item.id}}">❤️ 收藏</button>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="float-btn" bindtap="randomPick">
      <image src="/img/dice_icon.png" mode="aspectFit" style="width:28px;height:28px"></image>
    </view>
  </view>
</view>

<!-- ===== 图片预览弹窗 ===== -->
<view class="img-preview {{previewShow ? 'show' : ''}}" bindtap="closePreview">
  <image class="preview-img" src="{{previewSrc}}" mode="widthFix" wx:if="{{previewShow}}" catchtap=""></image>
</view>

<!-- ===== 随机选菜弹窗 ===== -->
<view class="modal-overlay {{randomShow ? 'show' : ''}}" bindtap="closeRandom">
  <view class="modal-box" catchtap="">
    <view class="modal-title">🎲 今天吃这个！</view>
    <image class="modal-img" src="{{randomDish.photo}}" mode="aspectFill" wx:if="{{randomDish.photo}}"></image>
    <text class="modal-emoji" wx:else>{{randomDish.emoji}}</text>
    <view class="modal-name">{{randomDish.name}}</view>
    <view class="modal-rating" wx:if="{{randomDish.rating}}">⭐{{randomDish.rating}}</view>
    <button class="modal-btn primary" catchtap="addRandomCart">加购物车</button>
    <button class="modal-btn" catchtap="randomPick">🎲 换一个</button>
    <button class="modal-btn cancel" catchtap="closeRandom">取消</button>
  </view>
</view>

<!-- ===== 自定义 Toast ===== -->
<view class="toast-overlay {{showToast ? 'show' : ''}}">
  <view class="toast-box">
    <image class="toast-icon" src="{{toastIcon}}" mode="aspectFit"></image>
    <text class="toast-text">{{toastText}}</text>
  </view>
</view>

<!-- ===== 飞入动效元素 ===== -->
<view class="fly-item {{flyShow ? 'fly-active' : ''}}" style="left:{{flyX}}px;top:{{flyY}}px;" wx:if="{{flyShow}}">
  <image src="{{flyPhoto}}" mode="aspectFill" wx:if="{{flyPhoto}}"></image>
  <text wx:else>{{flyEmoji}}</text>
</view>
