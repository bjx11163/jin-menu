page { background: #1a1a1a; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
.bg { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; }
.bg-wrapper { position: relative; height: 100vh; overflow: hidden; display: flex; flex-direction: column; }
.app { position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; }
.page-content { flex: 1; overflow-y: auto; padding: 24rpx 32rpx 140rpx 32rpx; padding-top: 100rpx; }
.header {
  display: flex; align-items: center; flex-shrink: 0;
  padding: 20rpx 32rpx; padding-top: calc(48rpx + env(safe-area-inset-top));
  background: rgba(255,245,240,0.3); backdrop-filter: blur(6px);
  border-bottom: 1px solid rgba(255,255,255,0.15);
}
.header-left { display: flex; align-items: center; gap: 12rpx; margin-right: auto; }
.header-title { font-size: 30rpx; font-weight: 700; color: #4A3034; }
.empty-hint { text-align: center; padding: 200rpx 0; color: rgba(74,48,52,0.5); font-size: 30rpx; }

.invoice-area { margin-top: 20rpx; }
.invoice-card { background: rgba(255,255,255,0.25); backdrop-filter: blur(6px); border-radius: 28rpx; border: 1px solid rgba(255,255,255,0.12); padding: 24rpx; margin-bottom: 12rpx; }
.inv-title { font-size: 32rpx; font-weight: 700; text-align: center; color: #4A3034; margin-bottom: 6rpx; }
.inv-date { font-size: 22rpx; color: rgba(74,48,52,0.5); text-align: center; margin-bottom: 20rpx; }
.inv-divider { height: 1px; background: rgba(74,48,52,0.1); margin: 16rpx 0; }
.inv-item { display: flex; justify-content: space-between; font-size: 26rpx; padding: 8rpx 0; color: #4A3034; }
.inv-item-left { display: flex; align-items: center; gap: 10rpx; }
.inv-note { font-size: 22rpx; color: rgba(74,48,52,0.5); font-style: italic; margin: 8rpx 0 8rpx 20rpx; }
.inv-total { text-align: right; font-size: 26rpx; font-weight: 600; color: #E88892; margin-top: 8rpx; }
.inv-footer { text-align: center; font-size: 22rpx; color: rgba(74,48,52,0.45); margin-top: 20rpx; }
.inv-rating { margin-top: 16rpx; padding-top: 16rpx; border-top: 1px solid rgba(74,48,52,0.08); display: block; }
.stars { display: flex; gap: 4rpx; margin-top: 6rpx; }
.inv-wish { margin-top: 16rpx; }
.inv-wish input { width: 100%; padding: 20rpx 16rpx; border: 1px solid rgba(74,48,52,0.12); border-radius: 12rpx; font-size: 26rpx; background: rgba(255,255,255,0.4); color: #4A3034; box-sizing: border-box; min-height: 72rpx; }
.inv-actions { display: flex; gap: 12rpx; margin-top: 12rpx; margin-bottom: 24rpx; }
.btn-primary { background: linear-gradient(135deg, #F5A0A8, #E88892); color: #fff; border: none; border-radius: 16rpx; padding: 20rpx 0; font-size: 28rpx; font-weight: 600; text-align: center; width: 100%; line-height: 1; }
.btn-primary::after { border: none; }
