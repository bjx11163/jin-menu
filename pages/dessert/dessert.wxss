page { background: transparent; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
.bg { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; }
.bg-wrapper { position: relative; height: 100vh; overflow: hidden; display: flex; flex-direction: column; }
.app { position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; }
.page-content { flex: 1; overflow-y: auto; padding: 24rpx 24rpx 180rpx 24rpx; padding-top: 100rpx; }
.header {
  display: flex; align-items: center; flex-shrink: 0;
  padding: 20rpx 24rpx; padding-top: calc(48rpx + env(safe-area-inset-top));
  background: rgba(255,245,240,0.3); backdrop-filter: blur(6px);
  border-bottom: 1px solid rgba(255,255,255,0.15);
}
.header-left { display: flex; align-items: center; gap: 12rpx; margin-right: auto; }
.header-title { font-size: 30rpx; font-weight: 700; color: #4A3034; }
.card {
  background: rgba(255,245,240,0.25);
  backdrop-filter: blur(6px); border-radius: 28rpx;
  border: 1px solid rgba(255,255,255,0.12);
  padding: 24rpx; margin-bottom: 12rpx;
}
.season-card {
  background: linear-gradient(135deg, rgba(245,160,168,0.15), rgba(255,245,240,0.25));
  border-color: rgba(245,160,168,0.2); text-align: center;
}
.season-label { font-size: 22rpx; color: #E88892; font-weight: 600; display: block; }
.season-text { font-size: 24rpx; color: #4A3034; display: block; margin-top: 6rpx; }
.dish-card { display: flex; gap: 12rpx; align-items: center; padding: 24rpx 28rpx; }
.dish-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; flex-shrink: 0; background: rgba(255,255,255,0.08); }
.dish-emoji { width: 160rpx; height: 160rpx; border-radius: 12rpx; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 60rpx; background: rgba(255,255,255,0.08); }
.dish-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.dish-name-row { display: flex; align-items: center; gap: 10rpx; }
.dish-name { font-size: 30rpx; font-weight: 600; color: #4A3034; }
.dish-rating { font-size: 24rpx; color: #E88892; font-weight: 600; }
.dish-tags { display: flex; flex-wrap: wrap; gap: 6rpx; margin: 6rpx 0; }
.tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 16rpx; background: rgba(255,245,240,0.3); color: rgba(74,48,52,0.55); }
.dish-act { display: flex; align-items: center; justify-content: flex-start; gap: 8rpx; margin-top: 6rpx; }
.dish-act .btn-light { font-size: 24rpx !important; padding: 8rpx 18rpx !important; min-width: 0 !important; height: auto !important; line-height: 1.4 !important; margin: 0 !important; border-radius: 12rpx !important; background: rgba(255,245,240,0.55) !important; }
.fav-btn { background: rgba(255,245,240,0.3) !important; font-size: 22rpx !important; padding: 6rpx 14rpx !important; min-width: 0 !important; height: auto !important; line-height: 1.4 !important; margin: 0 !important; border-radius: 12rpx !important; }
.toast-overlay { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); z-index: 200; display: none; pointer-events: none; }
.toast-overlay.show { display: flex; }
.toast-box { background: rgba(255,245,240,0.25); backdrop-filter: blur(6px); border: 1px solid rgba(255,255,255,0.15); border-radius: 28rpx; padding: 20rpx 40rpx; display: flex; align-items: center; gap: 12rpx; white-space: nowrap; }
.toast-icon { width: 48rpx; height: 48rpx; border-radius: 8rpx; flex-shrink: 0; }
.toast-text { font-size: 28rpx; color: #4A3034; font-weight: 500; white-space: nowrap; }
.img-preview { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 300; display: none; align-items: center; justify-content: center; }
.img-preview.show { display: flex; }
.preview-img { max-width: 90%; max-height: 80vh; border-radius: 16rpx; }
